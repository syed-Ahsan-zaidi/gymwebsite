generator client {
  provider   = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 1. Core Authentication & Multi-tenancy
model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
  role     Role   @default(MEMBER)
  adminApprovalStatus AdminApprovalStatus @default(APPROVED)

  // Gym Connection

  gym            GymProfile? @relation(fields: [gymId], references: [id], onDelete: Cascade)
  gymId          String?
  memberProfile  Member?
  trainerProfile Trainer?
  createdAt      DateTime    @default(now())

  // Indexes for efficient role-based queries
  @@index([gymId, role])
  @@index([role])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TRAINER
  MEMBER
}

enum AdminApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// 2. Gym Model (The Tenant)
model GymProfile {
  id          String   @id @default(cuid())
  gymName     String
  location    String
  facilities  String[]
  adminSecret String   @default("flex-secret")

  // Relations
  users     User[]
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  // Indexes for efficient pagination
  @@index([createdAt])
  @@index([createdAt, id])
}

// 3. Member Profile
model Member {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name           String
  phoneNumber    String
  age            Int
  weight         Float
  height         Float
  fitnessGoal    String
  allergies      String[]
  medicalHistory String?

  status    Status    @default(PENDING)
  joinedAt  DateTime  @default(now())
  expiresAt DateTime?

  payments  Payment[]
  trainerId String?
  trainer   Trainer?  @relation(fields: [trainerId], references: [id])

  chats           Chat[]
  plans           Plan[]
  attendance      Attendance[]
  workoutSessions WorkoutSession[]
  weightLogs      WeightLog[]
  requests        Request[]
  sessionBookings SessionBooking[]
  classEnrollments GroupClassEnrollment[]
}

enum Status {
  PENDING
  ACTIVE
  EXPIRED
}

// 4. Trainer Profile
model Trainer {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name           String
  specialization String
  experience     Int

  members Member[]
  plans   Plan[]
  requests Request[]
  availabilitySlots TrainerAvailabilitySlot[]
  sessionBookings   SessionBooking[]
  classes           GroupClass[]
}

// 5. Payments & Logs
model Payment {
  id            String        @id @default(cuid())
  amount        Float
  status        PaymentStatus @default(PENDING)
  receiptUrl    String?
  transactionId String?
  paymentMethod String?
  memberId      String
  member        Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PaymentStatus {
  PENDING
  SUCCESS
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum EnrollmentStatus {
  ENROLLED
  CANCELLED
  ATTENDED
}

model TrainerAvailabilitySlot {
  id          String   @id @default(cuid())
  trainerId   String
  trainer     Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  startTime   DateTime
  endTime     DateTime
  isRecurring Boolean  @default(false)
  weekday     Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings SessionBooking[]

  @@index([trainerId, isActive])
  @@index([trainerId, startTime])
  @@index([trainerId, weekday, isRecurring])
}

model SessionBooking {
  id        String        @id @default(cuid())
  trainerId String
  trainer   Trainer       @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  memberId  String
  member    Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  slotId    String?
  slot      TrainerAvailabilitySlot? @relation(fields: [slotId], references: [id], onDelete: SetNull)
  startTime DateTime
  endTime   DateTime
  status    BookingStatus @default(PENDING)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // 🔥 Optimization: In indexes mein endTime ko shamil karna zaroori hai 
  // taake overlap (lt/gt) logic database level par fast chale.
  @@index([trainerId, status, startTime, endTime])
  @@index([memberId, status, startTime, endTime])
  @@index([slotId])
}

model GroupClass {
  id        String   @id @default(cuid())
  trainerId String
  trainer   Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  title     String
  classType String
  startTime DateTime
  endTime   DateTime
  capacity  Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments GroupClassEnrollment[]

  @@index([trainerId, startTime, isActive])
}

model GroupClassEnrollment {
  id        String           @id @default(cuid())
  classId   String
  groupClass GroupClass      @relation(fields: [classId], references: [id], onDelete: Cascade)
  memberId  String
  member    Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  status    EnrollmentStatus @default(ENROLLED)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([classId, memberId])
  @@index([memberId, status])
  @@index([classId, status])
}

// 6. AI & Management Features
model Chat {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  message   String   @db.Text
  response  String   @db.Text
  createdAt DateTime @default(now())
}

model Plan {
  id        String  @id @default(cuid())
  memberId  String
  member    Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  trainerId String
  trainer   Trainer @relation(fields: [trainerId], references: [id])

  type       PlanType
  content    Json
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
}

enum PlanType {
  WORKOUT
  DIET
}

model Attendance {
  id       String   @id @default(cuid())
  date     DateTime @default(now())
  memberId String
  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
}

// schema.prisma mein niche ye add karein:

model WorkoutSession {
  id       String @id @default(cuid())
  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  exercises   Json // Isme array of objects store hoga: [{name, sets, reps, weight}]
  progress    Int      @default(0) // e.g., 100%
  completedAt DateTime @default(now())

  @@index([memberId])
}

model WeightLog {
  id       String   @id @default(cuid())
  weight   Float
  date     DateTime @default(now())
  memberId String
  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
}

model Request {
  id        String   @id @default(cuid())
  memberId  String
  trainerId String?  // Optional agar request general ho, ya required karein agar specific hai
  type      String   // "WORKOUT" ya "DIET"
  message   String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  // Relationships
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  trainer   Trainer? @relation(fields: [trainerId], references: [id])
}
